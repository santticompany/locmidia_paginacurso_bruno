# Credenciais de FTP para Hostinger
FTP_HOST=ftp.seudominio.com.br
FTP_USER=usuario@seudominio.com.br
FTP_PASSWORD=sua_senha_secreta_ftp

# Caminho remoto no servidor Hostinger (geralmente public_html ou public_html/pasta)
FTP_REMOTE_PATH=public_html

# Configurações Adicionais (Padrão: porta 21 e conexão TLS/Segura explícita ou simples)
FTP_PORT=21
# Defina FTP_SECURE como true se seu servidor exigir conexão segura FTPS (recomendado).
# Valores aceitos: true, false, "implicit"
FTP_SECURE=true
